@base = http://localhost:7331

### List tasks (empty on first run)
GET {{base}}/api/v1/tasks

### Create a task
# @name createTask
POST {{base}}/api/v1/tasks
Content-Type: application/json

{
  "title": "Buy groceries",
  "description": "Milk, eggs, bread"
}

### Create another task
POST {{base}}/api/v1/tasks
Content-Type: application/json

{
  "title": "Write tests"
}

### List all tasks
GET {{base}}/api/v1/tasks

### Get task by ID (use an ID from the list above)
GET {{base}}/api/v1/tasks/task_1

### Update task — mark as done
PATCH {{base}}/api/v1/tasks/task_1
Content-Type: application/json

{
  "done": true
}

### Update task — change title
PATCH {{base}}/api/v1/tasks/task_1
Content-Type: application/json

{
  "title": "Buy organic groceries"
}

### Delete a task
DELETE {{base}}/api/v1/tasks/task_1

### Get deleted task (→ 404)
GET {{base}}/api/v1/tasks/task_1

### Health check
GET {{base}}/health

### OpenAPI docs (browser)
GET {{base}}/docs
