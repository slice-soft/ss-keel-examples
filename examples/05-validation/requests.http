@base = http://localhost:7331

### Register — valid payload (→ 200)
POST {{base}}/users/register
Content-Type: application/json

{
  "name": "Jane Doe",
  "email": "jane@example.com",
  "password": "secret123",
  "age": 30
}

### Register — missing required fields (→ 422)
POST {{base}}/users/register
Content-Type: application/json

{}

### Register — invalid email and short password (→ 422)
POST {{base}}/users/register
Content-Type: application/json

{
  "name": "J",
  "email": "not-an-email",
  "password": "short",
  "age": 15
}

### Register — underage user (→ 422)
POST {{base}}/users/register
Content-Type: application/json

{
  "name": "Young User",
  "email": "young@example.com",
  "password": "validpass1",
  "age": 15
}

### Create order — valid payload (→ 200)
POST {{base}}/orders
Content-Type: application/json

{
  "customer_id": "cust_42",
  "items": [
    {"sku": "SKU-001", "quantity": 2, "price": 9.99},
    {"sku": "SKU-002", "quantity": 1, "price": 24.50}
  ]
}

### Create order — invalid item fields (→ 422)
POST {{base}}/orders
Content-Type: application/json

{
  "customer_id": "cust_42",
  "items": [
    {"sku": "", "quantity": 0, "price": -1}
  ]
}

### Create order — empty items list (→ 422)
POST {{base}}/orders
Content-Type: application/json

{
  "customer_id": "cust_42",
  "items": []
}

### Health check
GET {{base}}/health
