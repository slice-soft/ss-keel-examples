@base = http://localhost:7331

### Login as admin (alice)
# @name loginAdmin
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "password123"
}

### Login as regular user (bob)
# @name loginUser
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "bob@example.com",
  "password": "pass456"
}

### Invalid credentials (→ 401)
POST {{base}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "wrong"
}

### Get current user — uses token from loginAdmin response
GET {{base}}/api/me
Authorization: Bearer {{loginAdmin.response.body.token}}

### Access admin dashboard — admin role (→ 200)
GET {{base}}/api/admin/dashboard
Authorization: Bearer {{loginAdmin.response.body.token}}

### Access admin dashboard — non-admin (bob → 403)
GET {{base}}/api/admin/dashboard
Authorization: Bearer {{loginUser.response.body.token}}

### Access admin dashboard — no token (→ 401)
GET {{base}}/api/admin/dashboard

### Health check
GET {{base}}/health

### OpenAPI docs (browser)
GET {{base}}/docs
