@base = http://localhost:7331

### List products (paginated — default page=1 limit=20)
GET {{base}}/api/v1/products

### List products — page 2
GET {{base}}/api/v1/products?page=2&limit=5

### Create a product
# @name createProduct
POST {{base}}/api/v1/products
Content-Type: application/json

{
  "name": "Mechanical Keyboard",
  "description": "Cherry MX Brown switches",
  "price": 129.99,
  "stock": 50
}

### Create another product
POST {{base}}/api/v1/products
Content-Type: application/json

{
  "name": "USB-C Hub",
  "price": 39.99,
  "stock": 200
}

### Get product by ID
GET {{base}}/api/v1/products/1

### Update product — change price and stock
PATCH {{base}}/api/v1/products/1
Content-Type: application/json

{
  "price": 119.99,
  "stock": 45
}

### Delete product (soft delete — sets deleted_at)
DELETE {{base}}/api/v1/products/1

### Get deleted product (→ 404 after soft delete)
GET {{base}}/api/v1/products/1

### Health check (includes PostgreSQL status)
GET {{base}}/health

### OpenAPI docs (browser — requires running server)
GET {{base}}/docs
